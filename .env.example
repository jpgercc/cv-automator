# Obrigatório: chave da API Groq
GROQ_API_KEY=your_groq_api_key_here

# Opcional: chave da API Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Opcional: provedor de IA (groq | gemini). Padrão: groq
AI_PROVIDER=groq

# Opcional: modelo a ser usado. Padrão depende do provedor.
# Groq: llama-3.1-8b-instant
# Gemini: gemini-1.5-flash
AI_MODEL=llama-3.1-8b-instant

# Opcional: diretórios de saída, templates e dados
OUTPUT_DIR=output
TEMPLATE_DIR=templates
DATA_DIR=data
